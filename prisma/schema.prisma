  acceptedAt     DateTime? @db.Timestamptz(6) // 수락 시각
  acceptedUserId String? // 가입 완료된 User ID
  otpHash        String? // 인증번호 원문 대신 서버 비밀키 기반 HMAC 저장
  otpExpiresAt   DateTime? @db.Timestamptz(6) // 인증번호 만료 시각
  otpSentAt      DateTime? @db.Timestamptz(6) // 재발송 대기시간 계산 기준
  otpAttempts    Int       @default(0) // 연속 인증 실패 횟수
  otpVerifiedAt  DateTime? @db.Timestamptz(6) // 전화번호 인증 완료 시각
  otpConsumedAt  DateTime? @db.Timestamptz(6) // 가입 처리에서 1회 사용 예약된 시각
  lockedAt       DateTime? @db.Timestamptz(6) // 실패 횟수 초과 잠금 시각
  processingAttemptId String? // 가입 처리 1회 실행 식별자
  processingStartedAt DateTime? @db.Timestamptz(6) // PROCESSING 진입 시각(자동 재사용 금지)
  recoveryOperationId String? // 운영 복구 실행 식별자(원 가입 시도와 분리)
  recoveryAuthUserId  String? // 보상 삭제 실패 시 운영 복구할 Auth 사용자 ID
  recoveryError       String? // 운영 복구에 필요한 오류 요약
  createdBy      String // 초대 생성자 (ADMIN User ID)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  otpSends       StaffInvitationOtpSend[]
  recoveryLogs   StaffInvitationRecoveryLog[]
  authAttempts   StaffInvitationAuthAttempt[]

  @@index([status])
  @@index([phone])
  @@index([phone, status])
}

model StaffInvitationOtpSend {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  invitationId String
  phoneHash    String
  requestHash  String
  status       String // RESERVED, SENT, FAILED, TIMEOUT
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  invitation   StaffInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId, createdAt])
  @@index([phoneHash, createdAt])
  @@index([requestHash, createdAt])
}

model StaffInvitationRecoveryLog {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  invitationId String
  adminUserId  String
  action       String
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  invitation   StaffInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId, createdAt])
}

model StaffInvitationAuthAttempt {
  id           String   @id
  invitationId String
  authUserId   String?
  status       String
  error        String?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  invitation   StaffInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([invitationId, createdAt])
  @@index([authUserId])
}

model StaffPhoneVerification {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  ownerId        String
  phoneHash      String
  currentSendId  String?
  otpHash        String?
  otpExpiresAt   DateTime? @db.Timestamptz(6)
  attempts       Int       @default(0)
  lockedAt       DateTime? @db.Timestamptz(6)
  lastSentAt     DateTime? @db.Timestamptz(6)
  status         String    @default("PENDING")
  proofHash      String?
  proofExpiresAt DateTime? @db.Timestamptz(6)
  consumedAt     DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  sends          StaffPhoneVerificationSend[]

  @@unique([ownerId, phoneHash])
  @@index([ownerId, status])
  @@index([phoneHash, status])
}

model StaffPhoneVerificationSend {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  verificationId String
  ownerId        String
  phoneHash      String
  status         String
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  verification   StaffPhoneVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
  @@index([phoneHash, createdAt])
}

enum Role {
  ADMIN
  VICE_ADMIN
  INSTRUCTOR
  DRIVER
  PARENT
}

enum ShuttleRouteDirection {
  PICKUP
  DROPOFF
}

enum ShuttleRoutePlanStatus {
  DRAFT
  CONFIRMED
  COMPLETED
  ARCHIVED
}
