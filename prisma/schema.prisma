generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  INSTRUCTOR
  PARENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  phone     String?
  role      Role     @default(PARENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students  Student[] // For parents
  classes   Class[]   // For instructors
}

model Student {
  id        String   @id @default(uuid())
  name      String
  birthDate DateTime
  gender    String?
  parentId  String
  parent    User     @relation(fields: [parentId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]
  attendances Attendance[]
  payments    Payment[]
}

model Program {
  id                 String   @id @default(uuid())
  name               String
  targetAge          String?
  frequency          String?  // Legacy free-text (kept for backwards compat)
  weeklyFrequency    String?  // "주1회" | "주2회" | "주3회" | "매일반" (primary display badge)
  description        String?
  price              Int      // Fallback/default price
  order              Int      @default(0)  // Display sort order
  days               String?  // Comma-separated day keys: "Mon,Tue,Wed"
  priceWeek1         Int?     // 주1회 수강료
  priceWeek2         Int?     // 주2회 수강료
  priceWeek3         Int?     // 주3회 수강료
  priceDaily         Int?     // 매일반 수강료
  shuttleFeeOverride Int?     // null=auto, 0=no shuttle (weekend), >0=custom amount
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  classes          Class[]
  slotOverrides    ClassSlotOverride[]
  customClassSlots CustomClassSlot[]
}

model Class {
  id          String   @id @default(uuid())
  programId   String
  program     Program  @relation(fields: [programId], references: [id])
  instructorId String?
  instructor  User?    @relation(fields: [instructorId], references: [id])
  name        String   // e.g., "초등 저학년 A반"
  dayOfWeek   String   // e.g., "Mon", "Tue", etc.
  startTime   String   // e.g., "15:00"
  endTime     String   // e.g., "16:00"
  location    String?  // e.g., "A코트", "메인구장"
  capacity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]
  sessions    Session[]
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  status    String   @default("ACTIVE") // ACTIVE, CANCELLED, PAUSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, classId])
}

model Session {
  id        String   @id @default(uuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id])
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances Attendance[]
}

model Attendance {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  status    String   // PRESENT, ABSENT, LATE, EXCUSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, studentId])
}

model Payment {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  amount    Int
  status    String   // PENDING, COMPLETED, FAILED
  dueDate   DateTime
  paidDate  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Shuttle Bus system
model Route {
  id        String   @id @default(uuid())
  name      String
  driverName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stops     Stop[]
}

model Stop {
  id        String   @id @default(uuid())
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id])
  name      String
  time      String   // e.g., "14:30"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Academy General Settings (Singleton-like)
model AcademySettings {
  id                 String   @id @default("singleton")
  introductionTitle  String?  @default("다산신도시 No.1 스티즈농구교실")
  introductionText   String?  // Main welcome text
  shuttleInfoText    String?  // Text explaining shuttle bus service
  contactPhone       String?
  address            String?
  termsOfService     String?  @db.Text  // Program terms of service content
  // Visual Builder JSON Data
  pageDesignJSON     String?  @db.Text

  // Google Calendar ICS URL for annual events sync
  googleCalendarIcsUrl String?

  // Google Sheets URL for schedule data sync
  googleSheetsScheduleUrl String?

  // Class days of week for schedule calculation (comma-separated JS getDay values: 0=Sun,1=Mon,...,6=Sat)
  // e.g. "1,3" = 월·수, "2,4,6" = 화·목·토
  classDays            String?

  // Font settings (key strings matching FONT_OPTIONS in lib/fonts.ts)
  siteBodyFont         String?  @default("system")
  siteHeadingFont      String?  @default("system")

  // 체험/수강신청 페이지 콘텐츠 및 구글폼 연동
  trialTitle           String?  @default("체험수업 안내")
  trialContent         String?  @db.Text
  trialFormUrl         String?
  enrollTitle          String?  @default("수강신청 안내")
  enrollContent        String?  @db.Text
  enrollFormUrl        String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Per-slot admin overrides for the Google Sheets schedule
model ClassSlotOverride {
  id                String   @id @default(uuid())
  slotKey           String   @unique
  label             String?
  note              String?
  isHidden          Boolean  @default(false)
  capacity          Int      @default(12)
  startTimeOverride String?
  endTimeOverride   String?
  coachId           String?
  coach             Coach?   @relation(fields: [coachId], references: [id], onDelete: SetNull)
  programId         String?
  program           Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([coachId])
}

// Custom class slots not sourced from Google Sheets
model CustomClassSlot {
  id         String   @id @default(uuid())
  dayKey     String
  startTime  String
  endTime    String
  label      String
  gradeRange String?
  enrolled   Int      @default(0)
  capacity   Int      @default(12)
  note       String?
  isHidden   Boolean  @default(false)
  coachId    String?
  coach      Coach?   @relation(fields: [coachId], references: [id], onDelete: SetNull)
  programId  String?
  program    Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([dayKey, startTime])
  @@index([coachId])
}

// Coaches / Instructors Profile
model Coach {
  id          String   @id @default(uuid())
  name        String
  role        String   // e.g., "대표 원장", "수석 코치"
  description String?  @db.Text  // Bio / career details (multi-line)
  imageUrl    String?  // Profile picture URL
  order       Int      @default(0) // Control display order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  slots       ClassSlotOverride[]
  customSlots CustomClassSlot[]
}
