{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "fluid": true,
  "regions": ["icn1"],
  "functions": {
    "src/app/**/*": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/backup",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/social-posts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/push-outbox",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/site-ops-bot",
      "schedule": "0 17 * * *"
    }
  ]
}
