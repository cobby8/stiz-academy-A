generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  phone     String?
  role      Role      @default(PARENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  classes   Class[]
  students  Student[]
}

model Student {
  id          String       @id @default(uuid())
  name        String
  birthDate   DateTime
  gender      String?
  memo        String?
  parentId    String
  phone       String?      // 학생 휴대폰번호
  school      String?      // 학교명
  grade       String?      // 학년 (예: "2026년 초등 5학년")
  address     String?      // 주소
  enrollDate  DateTime?    // 입회일자
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
  enrollments Enrollment[]
  guardians   Guardian[]
  payments    Payment[]
  parent      User         @relation(fields: [parentId], references: [id])
}

model Program {
  id                 String              @id @default(uuid())
  name               String
  targetAge          String?
  frequency          String?
  description        String?
  price              Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  order              Int                 @default(0)
  days               String?
  priceWeek1         Int?
  priceWeek2         Int?
  priceWeek3         Int?
  priceDaily         Int?
  shuttleFeeOverride Int?
  weeklyFrequency    String?
  imageUrl           String?
  classes            Class[]
  slotOverrides      ClassSlotOverride[]
  customClassSlots   CustomClassSlot[]
}

model Class {
  id           String       @id @default(uuid())
  programId    String
  instructorId String?
  name         String
  dayOfWeek    String
  startTime    String
  endTime      String
  location     String?
  capacity     Int
  slotKey      String?      @unique  // 시간표 슬롯과 연결 (예: "Mon-3", "custom-uuid")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  instructor   User?        @relation(fields: [instructorId], references: [id])
  program      Program      @relation(fields: [programId], references: [id])
  enrollments  Enrollment[]
  sessions     Session[]
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  classId   String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class    @relation(fields: [classId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, classId])
}

model Session {
  id          String       @id @default(uuid())
  classId     String
  date        DateTime
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
  class       Class        @relation(fields: [classId], references: [id])
}

model Attendance {
  id        String   @id @default(uuid())
  sessionId String
  studentId String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  session   Session  @relation(fields: [sessionId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
}

model Payment {
  id        String    @id @default(uuid())
  studentId String
  amount    Int
  status    String
  dueDate   DateTime
  paidDate  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  student   Student   @relation(fields: [studentId], references: [id])
}

model Route {
  id         String   @id @default(uuid())
  name       String
  driverName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  stops      Stop[]
}

model Stop {
  id        String   @id @default(uuid())
  routeId   String
  name      String
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  route     Route    @relation(fields: [routeId], references: [id])
}

model AcademySettings {
  id                      String   @id @default("singleton")
  introductionTitle       String?  @default("다산신도시 No.1 스티즈농구교실")
  introductionText        String?
  shuttleInfoText         String?
  contactPhone            String?
  address                 String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  pageDesignJSON          String?
  googleCalendarIcsUrl    String?
  classDays               String?
  siteBodyFont            String?  @default("system")
  siteHeadingFont         String?  @default("system")
  termsOfService          String?
  trialTitle              String?  @default("체험수업 안내")
  trialContent            String?
  trialFormUrl            String?
  enrollTitle             String?  @default("수강신청 안내")
  enrollContent           String?
  enrollFormUrl           String?
  googleSheetsScheduleUrl String?
  youtubeUrl              String?
  philosophyText          String?
  facilitiesText          String?
  facilitiesImagesJSON    String?
}

model ClassSlotOverride {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  slotKey           String   @unique
  label             String?
  note              String?
  isHidden          Boolean  @default(false)
  capacity          Int      @default(12)
  startTimeOverride String?
  endTimeOverride   String?
  coachId           String?
  programId         String?
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  coach             Coach?   @relation(fields: [coachId], references: [id], onUpdate: NoAction)
  program           Program? @relation(fields: [programId], references: [id], onUpdate: NoAction)
}

model CustomClassSlot {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  dayKey     String
  startTime  String
  endTime    String
  label      String
  gradeRange String?
  enrolled   Int      @default(0)
  capacity   Int      @default(12)
  note       String?
  isHidden   Boolean  @default(false)
  coachId    String?
  programId  String?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  coach      Coach?   @relation(fields: [coachId], references: [id], onUpdate: NoAction)
  program    Program? @relation(fields: [programId], references: [id], onUpdate: NoAction)
}

model Coach {
  id          String              @id @default(uuid())
  name        String
  role        String
  description String?
  imageUrl    String?
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  slots       ClassSlotOverride[]
  customSlots CustomClassSlot[]
}

model SheetSlotCache {
  id        String   @id @default("singleton")
  slotsJson String   @default("[]")
  syncedAt  DateTime @default(now()) @updatedAt
}

model AnnualEvent {
  id          String    @id
  title       String
  date        DateTime
  endDate     DateTime?
  description String?
  category    String?   @default("일반")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
}

model GalleryPost {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  classId   String?
  title     String?
  caption   String?
  mediaJSON String   @default("[]")
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([classId])
  @@index([createdAt])
}

model Notice {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  title           String
  content         String
  targetType      String   @default("ALL")
  targetClassIds  String?
  attachmentsJSON String?
  isPinned        Boolean  @default(false)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([createdAt])
  @@index([targetType])
}

model Notification {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  type      String          // ATTENDANCE, NOTICE, PAYMENT
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, isRead])
  @@index([createdAt])
}

model PushSubscription {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId         String
  endpoint       String   @unique
  p256dh         String
  auth           String
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId])
}

model Feedback {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  studentId   String
  coachId     String
  sessionDate DateTime? @db.Timestamptz(6)
  category    String    @default("GENERAL") // SKILL, ATTITUDE, PHYSICAL, GENERAL
  title       String
  content     String
  rating      Int?      // 1~5
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([studentId, sessionDate])
  @@index([coachId])
}

model ParentRequest {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String
  studentId  String
  type       String          // ABSENCE, SHUTTLE, EARLY_LEAVE, OTHER
  title      String
  content    String
  date       DateTime?       @db.Timestamptz(6)
  status     String    @default("PENDING") // PENDING, CONFIRMED, COMPLETED
  adminNote  String?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Faq {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  question  String
  answer    String
  order     Int      @default(0)
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}

model Guardian {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  studentId String
  relation  String   // 관계 (예: "부", "모", "조부모" 등)
  name      String   // 보호자 이름
  phone     String?  // 보호자 연락처
  isPrimary Boolean  @default(false) // 주 보호자 여부
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

enum Role {
  ADMIN
  INSTRUCTOR
  PARENT
}
