generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String             @id @default(uuid())
  email                   String             @unique
  username                String?
  name                    String
  phone                   String?
  phoneVerifiedAt         DateTime?          @db.Timestamptz(6)
  authUserId              String?            @unique
  role                    Role               @default(PARENT)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  classes                 Class[]
  students                Student[]
  coach                   Coach?
  drivenShuttleRoutePlans ShuttleRoutePlan[] @relation("ShuttleRouteDriver")
}

model ParentAccountClaim {
  id                 String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  parentId           String
  applicationId      String?
  invoiceId          String?
  tokenHash          String    @unique
  phoneHash          String
  status             String    @default("PENDING")
  expiresAt          DateTime  @db.Timestamptz(6)
  otpHash            String?
  otpExpiresAt       DateTime? @db.Timestamptz(6)
  otpSentAt          DateTime? @db.Timestamptz(6)
  otpAttempts        Int       @default(0)
  lockedAt           DateTime? @db.Timestamptz(6)
  verifiedAt         DateTime? @db.Timestamptz(6)
  proofHash          String?
  proofExpiresAt     DateTime? @db.Timestamptz(6)
  consumedAt         DateTime? @db.Timestamptz(6)
  authUserId         String?
  processingAt       DateTime? @db.Timestamptz(6)
  processingAttemptId String?
  redirectPath       String    @default("/mypage")
  lastError          String?
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([parentId, status, createdAt])
  @@index([phoneHash, createdAt])
  @@index([applicationId])
  @@index([invoiceId])
}

model ParentAccountClaimOtpSend {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  claimId   String
  phoneHash String
  status    String
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([claimId, createdAt])
  @@index([phoneHash, createdAt])
}

model Student {
  id                  String                      @id @default(uuid())
  name                String
  birthDate           DateTime
  gender              String?
  memo                String?
  parentId            String
  branch              String? // 지점 원본값 (예: "2호점 : 행정복지센터...")
  phone               String? // 학생 휴대폰번호
  school              String? // 학교명
  grade               String? // 학년 (예: "2026년 초등 5학년")
  address             String? // 주소
  enrollDate          DateTime? // 입회일자
  referralSource      String? // 가입경로 (예: "지인소개", "네이버", "전단지" 등)
  uniformStatus       String? // 유니폼 상태 (예: "수령완료", "미수령", "추가주문" 등)
  basketballExp       String? // 농구 경험
  hopeNote            String? // 바라는 점
  agreementsJSON      String                      @default("{}") // 개인정보/이용약관/주의사항 동의 원본
  sourceImportRowId   String? // 마지막 시트 이관 원본 행
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  attendances         Attendance[]
  enrollments         Enrollment[]
  guardians           Guardian[]
  payments            Payment[]
  sessionNotes        StudentSessionNote[]
  importRawRows       StudentSheetRawRow[]
  registrationLedgers StudentRegistrationLedger[]
  shuttleRides        StudentShuttleRide[]
  shuttleRoutePassengers ShuttleRoutePassenger[]
  shuttleLocations    StudentShuttleLocation[]
  teamRosterEntries   StudentTeamRosterEntry[]
  parent              User                        @relation(fields: [parentId], references: [id])

  @@index([parentId])
  @@index([name, parentId])
  @@index([branch])
  @@index([sourceImportRowId])
}

model Program {
  id                 String              @id @default(uuid())
  name               String
  targetAge          String?
  frequency          String?
  description        String?
  price              Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  order              Int                 @default(0)
  days               String?
  priceWeek1         Int?
  priceWeek2         Int?
  priceWeek3         Int?
  priceDaily         Int?
  shuttleFeeOverride Int?
  weeklyFrequency    String?
  imageUrl           String?
  classes            Class[]
  slotOverrides      ClassSlotOverride[]
  customClassSlots   CustomClassSlot[]
  scheduleSlots      ScheduleSlot[]
}

model Class {
  id           String       @id @default(uuid())
  programId    String
  instructorId String?
  name         String
  dayOfWeek    String
  startTime    String
  endTime      String
  location     String?
  capacity     Int
  slotKey      String?      @unique // 시간표 슬롯과 연결 (예: "Mon-3", "custom-uuid")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  instructor   User?        @relation(fields: [instructorId], references: [id])
  program      Program      @relation(fields: [programId], references: [id])
  enrollments  Enrollment[]
  sessions     Session[]

  @@index([programId])
  @@index([instructorId])
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  classId   String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class    @relation(fields: [classId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, classId])
  @@index([classId, status])
  @@index([createdAt])
  @@index([status, updatedAt])
}

model Session {
  id                          String                     @id @default(uuid())
  classId                     String
  date                        DateTime
  specialProgramSessionDateId String?                    @unique
  sessionKey                  String?                    @unique // 같은 반·날짜의 수업 중복 생성을 막는 키
  status                      String                     @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED
  notes                       String?
  topic                       String? // 수업 주제 (예: "드리블 연습")
  plannedContent              String? // 수업 전에 작성한 예정 수업 내용
  content                     String? // 수업 중 실제로 진행한 내용
  photosJSON                  String? // 수업 사진 URL 배열 (JSON 문자열로 저장)
  coachId                     String? // 담당 코치 ID (Coach 테이블 참조용, FK 없음)
  startedAt                   DateTime?                  @db.Timestamptz(6) // 실제 수업 시작 시각
  endedAt                     DateTime?                  @db.Timestamptz(6) // 실제 수업 종료 시각
  startedByUserId             String? // 수업 시작을 확인한 User ID
  endedByUserId               String? // 수업 종료를 확인한 User ID
  published                   Boolean                    @default(false) // 학부모 공개 여부 (true일 때만 학부모가 열람 가능)
  publishedAt                 DateTime? // 발행 시각 (published=true로 변경된 시점)
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  attendances                 Attendance[]
  shuttleRoutePassengers      ShuttleRoutePassenger[]
  studentNotes                StudentSessionNote[]
  class                       Class                      @relation(fields: [classId], references: [id])
  specialProgramSessionDate   SpecialProgramSessionDate? @relation(fields: [specialProgramSessionDateId], references: [id], onDelete: Restrict)

  @@index([classId, date])
  @@index([status, date])
  @@index([startedAt])
  @@index([published, date])
}

model Attendance {
  id              String    @id @default(uuid())
  sessionId       String
  studentId       String
  status          String
  note            String?
  checkedAt       DateTime? @db.Timestamptz(6) // 출결 상태를 처음 확인한 시각
  arrivedAt       DateTime? @db.Timestamptz(6) // 지각생이 실제로 도착한 시각
  checkedByUserId String? // 출결을 처리한 User ID
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  session         Session   @relation(fields: [sessionId], references: [id])
  student         Student   @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([studentId])
}

// 학생별 수업 개별 코멘트 — 세션 리포트에서 학생마다 작성하는 메모
model StudentSessionNote {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  sessionId String
  studentId String
  note      String // 코치가 작성하는 개별 코멘트 (예: "드리블 실력 많이 향상됨")
  rating    Int? // 수업 참여도/성과 점수 (1~5, 선택사항)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  session   Session  @relation(fields: [sessionId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([studentId])
}

model Payment {
  id            String    @id @default(uuid())
  studentId     String
  classId       String?
  amount        Int
  status        String
  dueDate       DateTime
  paidDate      DateTime?
  type          String    @default("MONTHLY") // MONTHLY(월 수강료), SHUTTLE(셔틀), UNIFORM(유니폼), OTHER(기타)
  method        String? // 결제수단: RALLYZ(랠리즈), CARD(카드), CASH(현금영수증), UNPAID(미결제)
  description   String? // 청구 항목 설명 (예: "4월 수강료")
  month         Int? // 청구 대상 월 (1~12)
  year          Int? // 청구 대상 연도
  autoGenerated Boolean   @default(false) // 자동 생성 여부 (Cron/일괄 생성 구분)
  notifiedAt    DateTime? // 미납 알림 발송 시각
  invoiceNo     String?
  issuedAt      DateTime? @db.Timestamptz(6)
  payableUntil  DateTime? @db.Timestamptz(6)
  paidProvider  String?
  providerOrderId String?
  providerPaymentKey String?
  receiptUrl    String?
  paymentRequestedAt DateTime? @db.Timestamptz(6)
  lastReminderAt DateTime? @db.Timestamptz(6)
  reminderCount Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  student       Student   @relation(fields: [studentId], references: [id])
  invoice       PaymentInvoice?
  transactions  PaymentTransaction[]
  auditLogs     PaymentAuditLog[]

  @@index([year, month])
  @@index([status])
  @@index([studentId, year, month])
  @@index([studentId, dueDate])
  @@index([classId, status, dueDate])
  @@index([dueDate])
  @@index([status, dueDate])
  @@index([providerOrderId])
  @@index([providerPaymentKey])
  @@unique([id, classId])
}

model PaymentInvoice {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  paymentId      String    @unique
  studentId      String
  classId        String?
  parentId       String?
  invoiceNo      String    @unique
  status         String    @default("ISSUED")
  amount         Int
  title          String
  description    String?
  dueDate        DateTime  @db.Timestamptz(6)
  issuedAt       DateTime  @default(now()) @db.Timestamptz(6)
  sentAt         DateTime? @db.Timestamptz(6)
  paidAt         DateTime? @db.Timestamptz(6)
  canceledAt     DateTime? @db.Timestamptz(6)
  lastReminderAt DateTime? @db.Timestamptz(6)
  reminderCount  Int       @default(0)
  checkoutUrl    String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  payment        Payment   @relation(fields: [paymentId], references: [id])
  transactions   PaymentTransaction[]
  auditLogs      PaymentAuditLog[]

  @@index([parentId, status])
  @@index([studentId, dueDate])
  @@index([classId, status, dueDate])
}

model PaymentTransaction {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  paymentId      String
  invoiceId      String
  studentId      String
  parentId       String?
  provider       String    @default("TOSS")
  orderId        String    @unique
  paymentKey     String?   @unique
  orderName      String
  amount         Int
  status         String    @default("READY")
  method         String?
  receiptUrl     String?
  failureCode    String?
  failureMessage String?
  requestedAt    DateTime  @default(now()) @db.Timestamptz(6)
  approvedAt     DateTime? @db.Timestamptz(6)
  rawResponse    Json?
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  payment        Payment   @relation(fields: [paymentId], references: [id])
  invoice        PaymentInvoice @relation(fields: [invoiceId], references: [id])
  auditLogs      PaymentAuditLog[]

  @@index([invoiceId, status])
  @@index([paymentId, status])
}

model PaymentWebhookEvent {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  provider    String    @default("TOSS")
  eventId     String?
  eventType   String?
  paymentKey  String?
  orderId     String?
  processed   Boolean   @default(false)
  receivedAt  DateTime  @default(now()) @db.Timestamptz(6)
  processedAt DateTime? @db.Timestamptz(6)
  payload     Json
  error       String?

  @@index([orderId])
  @@index([paymentKey])
  @@unique([provider, eventId])
}

model PaymentAuditLog {
  id            String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  paymentId     String?
  invoiceId     String?
  transactionId String?
  actorType     String
  actorId       String?
  action        String
  message       String?
  metadata      Json?
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  payment       Payment?  @relation(fields: [paymentId], references: [id])
  invoice       PaymentInvoice? @relation(fields: [invoiceId], references: [id])
  transaction   PaymentTransaction? @relation(fields: [transactionId], references: [id])

  @@index([paymentId, createdAt])
}

model StaffPaymentConfirmationRequest {
  id                String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  paymentId         String
  invoiceId         String
  classId           String
  studentId         String
  requestedByUserId String
  method            String
  amount            Int
  receivedAt        DateTime  @db.Timestamptz(6)
  note              String?
  status            String    @default("PENDING")
  reviewedByUserId  String?
  reviewedAt        DateTime? @db.Timestamptz(6)
  reviewNote        String?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([status, createdAt])
  @@index([paymentId, createdAt])
  @@index([classId, status])
}

// 청구 템플릿 — 매월 자동 청구서 생성의 기준 데이터
model BillingTemplate {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String // 템플릿 이름 (예: "초등 주3회 수강료")
  amount      Int // 청구 금액
  type        String   @default("MONTHLY") // MONTHLY, SHUTTLE, UNIFORM, OTHER
  description String? // 청구서에 표시될 설명
  isActive    Boolean  @default(true) // 활성 여부 (비활성이면 자동 생성에서 제외)
  dueDay      Int      @default(10) // 매월 납부 기한일 (1~28)
  programId   String? // 연결된 프로그램 (선택)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([isActive])
}

model Route {
  id         String   @id @default(uuid())
  name       String
  driverName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  stops      Stop[]
}

model Stop {
  id        String   @id @default(uuid())
  routeId   String
  name      String
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  route     Route    @relation(fields: [routeId], references: [id])
}

model AcademySettings {
  id                          String   @id @default("singleton")
  introductionTitle           String?  @default("다산신도시 No.1 스티즈농구교실")
  introductionText            String?
  shuttleInfoText             String?
  contactPhone                String?
  address                     String?
  operatingHours              String?
  privacyPolicy               String?
  footerDescription           String?
  footerCopyright             String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  pageDesignJSON              String?
  googleCalendarIcsUrl        String?
  classDays                   String?
  siteBodyFont                String?  @default("system")
  siteHeadingFont             String?  @default("system")
  termsOfService              String?
  trialTitle                  String?  @default("체험수업 안내")
  trialContent                String?
  trialFormUrl                String?
  enrollTitle                 String?  @default("수강신청 안내")
  enrollContent               String?
  enrollFormUrl               String?
  googleSheetsScheduleUrl     String?
  youtubeUrl                  String?
  instagramUrl                String?
  instagramBusinessAccountId  String?
  instagramAutoPublishEnabled Boolean  @default(false)
  kakaoChannelUrl             String?
  philosophyText              String?
  facilitiesText              String?
  facilitiesImagesJSON        String?
  naverPlaceUrl               String? // 네이버 플레이스 리뷰 URL
  uniformFormUrl              String? // 유니폼 신청 구글폼 URL
  useBuiltInTrialForm         Boolean  @default(false) // true=자체 폼, false=구글폼 외부 링크
  useBuiltInEnrollForm        Boolean  @default(false) // true=자체 폼, false=구글폼 외부 링크
}

model ClassSlotOverride {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  slotKey           String   @unique
  label             String?
  note              String?
  isHidden          Boolean  @default(false)
  capacity          Int      @default(12)
  startTimeOverride String?
  endTimeOverride   String?
  coachId           String?
  programId         String?
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  coach             Coach?   @relation(fields: [coachId], references: [id], onUpdate: NoAction)
  program           Program? @relation(fields: [programId], references: [id], onUpdate: NoAction)
}

model CustomClassSlot {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  dayKey     String
  startTime  String
  endTime    String
  label      String
  gradeRange String?
  enrolled   Int      @default(0)
  capacity   Int      @default(12)
  note       String?
  isHidden   Boolean  @default(false)
  coachId    String?
  programId  String?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  coach      Coach?   @relation(fields: [coachId], references: [id], onUpdate: NoAction)
  program    Program? @relation(fields: [programId], references: [id], onUpdate: NoAction)
}

model ScheduleImportBatch {
  id             String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  source         String                @default("GOOGLE_SHEETS")
  sourceUrl      String?
  status         String                @default("PENDING")
  importedBy     String?
  totalRows      Int                   @default(0)
  validRows      Int                   @default(0)
  errorRows      Int                   @default(0)
  message        String?
  rawSummaryJSON String?
  createdAt      DateTime              @default(now()) @db.Timestamptz(6)
  completedAt    DateTime?             @db.Timestamptz(6)
  slots          ScheduleSlot[]
  issues         ScheduleImportIssue[]

  @@index([status, createdAt])
  @@index([source, createdAt])
}

model ScheduleImportIssue {
  id        String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  batchId   String
  rowNumber Int?
  slotKey   String?
  severity  String              @default("ERROR")
  message   String
  rawJSON   String?
  createdAt DateTime            @default(now()) @db.Timestamptz(6)
  batch     ScheduleImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([batchId])
  @@index([severity])
  @@index([slotKey])
}

model ScheduleSlot {
  id               String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  slotKey          String               @unique
  source           String               @default("DB")
  period           Int?
  dayKey           String
  dayLabel         String?
  isWeekend        Boolean              @default(false)
  startTime        String
  endTime          String
  label            String?
  gradeRange       String?
  gradesJSON       String               @default("[]")
  enrolledSnapshot Int                  @default(0)
  capacity         Int                  @default(12)
  note             String?
  isHidden         Boolean              @default(false)
  displayOrder     Int                  @default(0)
  activeFrom       DateTime?            @db.Timestamptz(6)
  activeTo         DateTime?            @db.Timestamptz(6)
  coachId          String?
  programId        String?
  importBatchId    String?
  rawJSON          String?
  createdAt        DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  coach            Coach?               @relation(fields: [coachId], references: [id], onUpdate: NoAction)
  program          Program?             @relation(fields: [programId], references: [id], onUpdate: NoAction)
  importBatch      ScheduleImportBatch? @relation(fields: [importBatchId], references: [id], onUpdate: NoAction)

  @@index([dayKey, startTime])
  @@index([isHidden])
  @@index([coachId])
  @@index([programId])
  @@index([importBatchId])
  @@index([source])
}

model Coach {
  id            String              @id @default(uuid())
  name          String
  role          String
  description   String?
  imageUrl      String?
  phone         String? // SMS 수신 전화번호 (예: "01012345678")
  userId        String?             @unique // User 테이블과 연결 (INSTRUCTOR 역할 사용자)
  order         Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  user          User?               @relation(fields: [userId], references: [id], onUpdate: NoAction)
  slots         ClassSlotOverride[]
  customSlots   CustomClassSlot[]
  scheduleSlots ScheduleSlot[]
}

model SheetSlotCache {
  id        String   @id @default("singleton")
  slotsJson String   @default("[]")
  syncedAt  DateTime @default(now()) @updatedAt
}

model StudentSheetImportBatch {
  id                   String                      @id @default(dbgenerated("(gen_random_uuid())::text"))
  source               String                      @default("GOOGLE_SHEETS")
  spreadsheetId        String?
  spreadsheetTitle     String?
  sourceUrl            String?
  importedBy           String?
  status               String                      @default("PENDING")
  totalRows            Int                         @default(0)
