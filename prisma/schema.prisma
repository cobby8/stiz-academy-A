generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  phone     String?
  role      Role      @default(PARENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  classes   Class[]
  students  Student[]
}

model Student {
  id          String       @id @default(uuid())
  name        String
  birthDate   DateTime
  gender      String?
  memo        String?
  parentId    String
  phone       String?      // 학생 휴대폰번호
  school      String?      // 학교명
  grade       String?      // 학년 (예: "2026년 초등 5학년")
  address     String?      // 주소
  enrollDate  DateTime?    // 입회일자
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances  Attendance[]
  enrollments  Enrollment[]
  guardians    Guardian[]
  payments     Payment[]
  sessionNotes StudentSessionNote[]
  parent       User         @relation(fields: [parentId], references: [id])
}

model Program {
  id                 String              @id @default(uuid())
  name               String
  targetAge          String?
  frequency          String?
  description        String?
  price              Int
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  order              Int                 @default(0)
  days               String?
  priceWeek1         Int?
  priceWeek2         Int?
  priceWeek3         Int?
  priceDaily         Int?
  shuttleFeeOverride Int?
  weeklyFrequency    String?
  imageUrl           String?
  classes            Class[]
  slotOverrides      ClassSlotOverride[]
  customClassSlots   CustomClassSlot[]
}

model Class {
  id           String       @id @default(uuid())
  programId    String
  instructorId String?
  name         String
  dayOfWeek    String
  startTime    String
  endTime      String
  location     String?
  capacity     Int
  slotKey      String?      @unique  // 시간표 슬롯과 연결 (예: "Mon-3", "custom-uuid")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  instructor   User?        @relation(fields: [instructorId], references: [id])
  program      Program      @relation(fields: [programId], references: [id])
  enrollments  Enrollment[]
  sessions     Session[]
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  classId   String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class    @relation(fields: [classId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, classId])
}

model Session {
  id          String       @id @default(uuid())
  classId     String
  date        DateTime
  notes       String?
  topic       String?      // 수업 주제 (예: "드리블 연습")
  content     String?      // 수업 상세 내용
  photosJSON  String?      // 수업 사진 URL 배열 (JSON 문자열로 저장)
  coachId     String?      // 담당 코치 ID (Coach 테이블 참조용, FK 없음)
  published   Boolean      @default(false)  // 학부모 공개 여부 (true일 때만 학부모가 열람 가능)
  publishedAt DateTime?    // 발행 시각 (published=true로 변경된 시점)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
  studentNotes StudentSessionNote[]
  class       Class        @relation(fields: [classId], references: [id])
}

model Attendance {
  id        String   @id @default(uuid())
  sessionId String
  studentId String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  session   Session  @relation(fields: [sessionId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
}

// 학생별 수업 개별 코멘트 — 세션 리포트에서 학생마다 작성하는 메모
model StudentSessionNote {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  sessionId String
  studentId String
  note      String   // 코치가 작성하는 개별 코멘트 (예: "드리블 실력 많이 향상됨")
  rating    Int?     // 수업 참여도/성과 점수 (1~5, 선택사항)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  session   Session  @relation(fields: [sessionId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
  @@index([studentId])
}

model Payment {
  id            String    @id @default(uuid())
  studentId     String
  amount        Int
  status        String
  dueDate       DateTime
  paidDate      DateTime?
  type          String    @default("MONTHLY")  // MONTHLY(월 수강료), SHUTTLE(셔틀), UNIFORM(유니폼), OTHER(기타)
  description   String?                        // 청구 항목 설명 (예: "4월 수강료")
  month         Int?                           // 청구 대상 월 (1~12)
  year          Int?                           // 청구 대상 연도
  autoGenerated Boolean   @default(false)      // 자동 생성 여부 (Cron/일괄 생성 구분)
  notifiedAt    DateTime?                      // 미납 알림 발송 시각
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  student       Student   @relation(fields: [studentId], references: [id])

  @@index([year, month])
  @@index([status])
}

// 청구 템플릿 — 매월 자동 청구서 생성의 기준 데이터
model BillingTemplate {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String                          // 템플릿 이름 (예: "초등 주3회 수강료")
  amount      Int                             // 청구 금액
  type        String   @default("MONTHLY")    // MONTHLY, SHUTTLE, UNIFORM, OTHER
  description String?                         // 청구서에 표시될 설명
  isActive    Boolean  @default(true)         // 활성 여부 (비활성이면 자동 생성에서 제외)
  dueDay      Int      @default(10)           // 매월 납부 기한일 (1~28)
  programId   String?                         // 연결된 프로그램 (선택)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([isActive])
}

model Route {
  id         String   @id @default(uuid())
  name       String
  driverName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  stops      Stop[]
}

model Stop {
  id        String   @id @default(uuid())
  routeId   String
  name      String
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  route     Route    @relation(fields: [routeId], references: [id])
}

model AcademySettings {
  id                      String   @id @default("singleton")
  introductionTitle       String?  @default("다산신도시 No.1 스티즈농구교실")
  introductionText        String?
  shuttleInfoText         String?
  contactPhone            String?
  address                 String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  pageDesignJSON          String?
  googleCalendarIcsUrl    String?
  classDays               String?
  siteBodyFont            String?  @default("system")
  siteHeadingFont         String?  @default("system")
  termsOfService          String?
  trialTitle              String?  @default("체험수업 안내")
  trialContent            String?
  trialFormUrl            String?
  enrollTitle             String?  @default("수강신청 안내")
  enrollContent           String?
  enrollFormUrl           String?
  googleSheetsScheduleUrl String?
  youtubeUrl              String?
  philosophyText          String?
  facilitiesText          String?
  facilitiesImagesJSON    String?
  naverPlaceUrl           String?  // 네이버 플레이스 리뷰 URL
}

model ClassSlotOverride {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  slotKey           String   @unique
  label             String?
  note              String?
  isHidden          Boolean  @default(false)
  capacity          Int      @default(12)
  startTimeOverride String?
  endTimeOverride   String?
  coachId           String?
  programId         String?
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  coach             Coach?   @relation(fields: [coachId], references: [id], onUpdate: NoAction)
  program           Program? @relation(fields: [programId], references: [id], onUpdate: NoAction)
}

model CustomClassSlot {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  dayKey     String
  startTime  String
  endTime    String
  label      String
  gradeRange String?
  enrolled   Int      @default(0)
  capacity   Int      @default(12)
  note       String?
  isHidden   Boolean  @default(false)
  coachId    String?
  programId  String?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  coach      Coach?   @relation(fields: [coachId], references: [id], onUpdate: NoAction)
  program    Program? @relation(fields: [programId], references: [id], onUpdate: NoAction)
}

model Coach {
  id          String              @id @default(uuid())
  name        String
  role        String
  description String?
  imageUrl    String?
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  slots       ClassSlotOverride[]
  customSlots CustomClassSlot[]
}

model SheetSlotCache {
  id        String   @id @default("singleton")
  slotsJson String   @default("[]")
  syncedAt  DateTime @default(now()) @updatedAt
}

model AnnualEvent {
  id            String    @id
  title         String
  date          DateTime
  endDate       DateTime?
  description   String?
  category      String?   @default("일반")
  googleEventId String?   // 구글 캘린더 이벤트 ID (양방향 동기화용)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
}

model GalleryPost {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  classId   String?
  title     String?
  caption   String?
  mediaJSON String   @default("[]")
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([classId])
  @@index([createdAt])
}

model Notice {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  title           String
  content         String
  targetType      String   @default("ALL")
  targetClassIds  String?
  attachmentsJSON String?
  isPinned        Boolean  @default(false)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([createdAt])
  @@index([targetType])
}

model Notification {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  type      String          // ATTENDANCE, NOTICE, PAYMENT
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, isRead])
  @@index([createdAt])
}

model PushSubscription {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId         String
  endpoint       String   @unique
  p256dh         String
  auth           String
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId])
}

model Feedback {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  studentId   String
  coachId     String
  sessionDate DateTime? @db.Timestamptz(6)
  category    String    @default("GENERAL") // SKILL, ATTITUDE, PHYSICAL, GENERAL
  title       String
  content     String
  rating      Int?      // 1~5
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([studentId, sessionDate])
  @@index([coachId])
}

model ParentRequest {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String
  studentId  String
  type       String          // ABSENCE, SHUTTLE, EARLY_LEAVE, OTHER
  title      String
  content    String
  date       DateTime?       @db.Timestamptz(6)
  status     String    @default("PENDING") // PENDING, CONFIRMED, COMPLETED
  adminNote  String?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Faq {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  question  String
  answer    String
  order     Int      @default(0)
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}

// 학부모 후기 — 관리자가 등록/수정/삭제/순서변경 가능
model Testimonial {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name      String   // 작성자명 (예: "김O O")
  info      String   // 관계/정보 (예: "초3 학부모")
  text      String   // 후기 내용
  rating    Int      @default(5)  // 별점 1~5
  order     Int      @default(0)  // 표시 순서 (작을수록 먼저)
  isPublic  Boolean  @default(true)  // 공개 여부
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}

model Guardian {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  studentId String
  relation  String   // 관계 (예: "부", "모", "조부모" 등)
  name      String   // 보호자 이름
  phone     String?  // 보호자 연락처
  isPrimary Boolean  @default(false) // 주 보호자 여부
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([studentId])
}

// 체험수업 CRM — 체험 신청부터 정규 등록 전환까지 추적하는 리드 테이블
model TrialLead {
  id                 String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  childName          String
  childAge           String?
  parentName         String
  parentPhone        String
  source             String    @default("WEBSITE")   // WEBSITE, NAVER, REFERRAL, OTHER
  status             String    @default("NEW")       // NEW, CONTACTED, SCHEDULED, ATTENDED, CONVERTED, LOST
  scheduledDate      DateTime? @db.Timestamptz(6)
  scheduledClassId   String?
  attendedDate       DateTime? @db.Timestamptz(6)
  convertedDate      DateTime? @db.Timestamptz(6)
  convertedStudentId String?
  lostReason         String?
  memo               String?
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@index([createdAt])
}

// 대기자 관리 — 반 정원 초과 시 대기열에 등록, 자리 생기면 제안/수락/거절 처리
model Waitlist {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  studentId   String
  classId     String
  priority    Int       @default(0)              // 우선순위 (낮을수록 먼저, 자동 증가)
  status      String    @default("WAITING")      // WAITING, OFFERED, ENROLLED, CANCELLED
  offeredAt   DateTime? @db.Timestamptz(6)       // 자리 제안 시각
  respondBy   DateTime? @db.Timestamptz(6)       // 응답 기한 (offeredAt + 3일)
  memo        String?                            // 관리자 메모
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([studentId, classId])
  @@index([classId, status])
}

// 보강/메이크업 수업 예약 — 결석 시 다른 반에서 보충 수업을 받는 기록
model MakeupSession {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  studentId       String
  originalClassId String    // 원래 수강 중인 반 ID
  originalDate    DateTime  @db.Timestamptz(6) // 결석한 날짜
  makeupClassId   String    // 보강 받을 반 ID
  makeupDate      DateTime  @db.Timestamptz(6) // 보강 수업 날짜
  status          String    @default("BOOKED") // BOOKED, ATTENDED, CANCELLED, NO_SHOW
  requestId       String?   // 학부모 결석 요청 ID (ParentRequest 연결, 선택)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([studentId])
  @@index([makeupClassId, makeupDate])
}

// 기술 카테고리 마스터 — 드리블, 슈팅, 패스 등 평가 항목을 관리
model SkillCategory {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name        String
  icon        String?
  order       Int      @default(0)
  maxLevel    Int      @default(5)
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}

// 원생별 기술 기록 — 코치가 원생의 카테고리별 레벨을 평가한 이력
model SkillRecord {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  studentId   String
  categoryId  String
  level       Int
  assessedBy  String
  assessedAt  DateTime @default(now()) @db.Timestamptz(6)
  note        String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([studentId, categoryId])
  @@index([assessedAt])
}

enum Role {
  ADMIN
  INSTRUCTOR
  PARENT
}
